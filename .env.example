# Copy to .env and fill in values. .env is gitignored.
# Used for development so API keys and secrets are not stored in config files.

# App settings (optional overrides; default DateFormat: YYYY-MM-DD)
# ETNA_SETTINGS_DATEFORMAT=DD/MM/YYYY

# Additional currencies (main currency from MainCurrency; do not repeat). Add more as _1, _2, etc.
# ETNA_SETTINGS_ADDITIONALCURRENCIES_0=EUR
# ETNA_SETTINGS_ADDITIONALCURRENCIES_1=USD

# Massive (market data) API key(s). First key: ETNA_MARKETDATAIMPORTERS_MASSIVE_APIKEYS_0
# Add more keys as ETNA_MARKETDATAIMPORTERS_MASSIVE_APIKEYS_1, _2, etc. for rotation.
# ETNA_MARKETDATAIMPORTERS_MASSIVE_APIKEYS_0=your_api_key_here
